# MongoDB settings
MONGO_URI=mongodb://localhost:27017
DATABASE_NAME=enterprise_support

# Security settings
JWT_SECRET_KEY=generate-a-strong-random-key-here-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
MFA_JWT_SECRET_KEY=another-random-strong-key-for-mfa-tokens

# Google Gemini AI settings
GEMINI_API_KEY=your-gemini-api-key-here

# Email notifications (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=support@company.com
MOCK_SERVICES=true

# Password Reset Integration (Web_Auth)
WEB_AUTH_URL=http://localhost:5000
RESET_API_KEY=unisys-reset-secret-key-2024
