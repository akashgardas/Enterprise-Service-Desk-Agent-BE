# ==========================================
# Python Core & Byte-compiled / Optimized files
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Environments (Virtualenvs)
# ==========================================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ==========================================
# Secrets & Configuration
# ==========================================
# CRITICAL: Never commit your .env files containing:
# - MongoDB URIs (Motor)
# - Google Gemini API Keys (google-generativeai)
# - JWT Secret Keys (PyJWT)
# - TOTP master keys or secrets
.env.*
!.env.example
*.pem
*.key
credentials.json
client_secret.json

# ==========================================
# Machine Learning & Data (scikit-learn)
# ==========================================
# Ignore serialized models, vectorizers, and tf-idf matrices
*.pkl
*.joblib
*.h5
*.hdf5
*.npy
*.npz

# Ignore local datasets or ticket dumps used for testing/training
*.csv
*.tsv
*.parquet
data/
datasets/

# ==========================================
# Packages & Distribution
# ==========================================
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==========================================
# Logs & Databases
# ==========================================
*.log
logs/
# If you run local mongo dumps
dump/

# ==========================================
# Testing & Type Checking
# ==========================================
.pytest_cache/
.tox/
.nox/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.pyre/
.ruff_cache/

# ==========================================
# OS & IDE specifics
# ==========================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
